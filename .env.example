# ============================================================================
# VerdFrut — Variables de Entorno (template)
# Copia a .env.local en cada app y rellena con valores reales.
# Nunca committees .env, .env.local ni archivos con credenciales reales.
# ============================================================================

# ----------------------------------------------------------------------------
# SUPABASE (por tenant en apps/platform y apps/driver)
# Cada cliente tiene SU propio proyecto Supabase. Estas variables apuntan
# al proyecto del tenant que esta app está sirviendo en este deploy.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=

# ----------------------------------------------------------------------------
# PUSH NOTIFICATIONS (VAPID — mismas claves para todos los tenants)
# Generar con: npx web-push generate-vapid-keys
# ----------------------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@verdfrut.com

# ----------------------------------------------------------------------------
# MAPS (Mapbox GL JS)
# Crear cuenta en mapbox.com, obtener access tokens
# ----------------------------------------------------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxx
MAPBOX_DIRECTIONS_TOKEN=sk.xxx

# ----------------------------------------------------------------------------
# IA (Claude Vision para extracción de tickets)
# https://console.anthropic.com/
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxx

# ----------------------------------------------------------------------------
# OPTIMIZER (FastAPI + VROOM)
# En desarrollo local: http://localhost:8000
# En docker-compose: http://optimizer:8000
# ----------------------------------------------------------------------------
OPTIMIZER_URL=http://optimizer:8000
OPTIMIZER_API_KEY=

# ----------------------------------------------------------------------------
# APP
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://neto.verdfrut.com
NEXT_PUBLIC_TENANT_SLUG=neto

# ============================================================================
# CONTROL PLANE (solo apps/control-plane)
# ============================================================================

# Supabase del proyecto control plane (NO de un cliente)
# CONTROL_PLANE_SUPABASE_URL=
# CONTROL_PLANE_SUPABASE_ANON_KEY=
# CONTROL_PLANE_SERVICE_ROLE_KEY=

# Registro de tenants (mapeo slug → credenciales Supabase)
# TENANT_REGISTRY_PATH=/etc/verdfrut/tenants.json

# Para provisioning automático de nuevos tenants
# SUPABASE_MANAGEMENT_API_TOKEN=

# Token interno para sync de KPIs
# INTERNAL_SYNC_TOKEN=

# ============================================================================
# OPTIMIZER (services/optimizer — variables del container)
# ============================================================================
# VROOM_BIN_PATH=/usr/local/bin/vroom
# OPTIMIZER_API_KEY=  (debe coincidir con el de las apps)
# LOG_LEVEL=info
# PORT=8000

# ============================================================================
# OBSERVABILIDAD (Sentry — ADR-051)
# Compartido por las 3 apps (platform, driver, control-plane). Free tier = 1
# proyecto en Sentry, los apps se distinguen con tag `app` automáticamente.
# ============================================================================
# DSN público (browser + server). Si está vacío, Sentry no se inicializa y la
# app sigue funcionando sin telemetría.
NEXT_PUBLIC_SENTRY_DSN=

# Auth token para subir source maps en build. Solo en CI/Vercel. Sin esto el
# build pasa pero los stack traces en Sentry no son legibles (apuntan al
# bundle minificado en vez del código TS original).
SENTRY_AUTH_TOKEN=

# Slug de organización y proyecto en Sentry (visible en la URL del dashboard).
SENTRY_ORG=tripdrive
SENTRY_PROJECT=tripdrive

# Override del environment tag (Sentry lo usa para filtrar dashboard).
# Si no se setea, se infiere de VERCEL_ENV o NODE_ENV.
# SENTRY_ENVIRONMENT=production

# Fuerza Sentry incluso en local dev (debug del SDK). Sin esto, en NODE_ENV=development
# Sentry NO envía eventos para evitar ruido en el dashboard.
# SENTRY_FORCE_LOCAL=1
