{
  "name": "verdfrut",
  "version": "0.1.0",
  "private": true,
  "description": "VerdFrut — SaaS multi-tenant para optimización y ejecución de rutas de reparto",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --concurrency=20",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "provision:tenant": "bash scripts/provision-tenant.sh",
    "migrate:all": "bash scripts/migrate-all-tenants.sh"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "pnpm": {
    "overrides": {
      "expo-updates": "0.27.5"
    }
  }
}
