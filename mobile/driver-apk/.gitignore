# Secretos: NUNCA commitear el keystore ni sus passwords.
# Si pierdes el keystore, NO puedes actualizar la APK firmada con él.
# Guárdalo aparte (1Password, vault, USB encriptado, etc.).
.keystore/
*.jks
*.keystore
*.password
*.passwords.txt

# Build artifacts (Bubblewrap genera muchos al build)
build/
app/build/
.gradle/
local.properties

# Artifacts intermedios del firmado (apksigner)
*.idsig
app-release-aligned.apk
app-release-bundle.aab.idsig

# Output APK firmada — sí queremos referencia pero no en repo
*.apk
*.aab
app-release-bundle.aab
app-release-signed.apk

# Bubblewrap creará estos al init
android.keystore
*.json.bak

# macOS
.DS_Store
