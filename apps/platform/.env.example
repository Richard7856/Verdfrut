# Para desarrollo local, copia a .env.local y rellena.
# En producción, cada deploy de cliente apunta a su propio Supabase.

NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@verdfrut.com

NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxx
MAPBOX_DIRECTIONS_TOKEN=sk.xxx

ANTHROPIC_API_KEY=sk-ant-xxx

OPTIMIZER_URL=http://localhost:8000
OPTIMIZER_API_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_TENANT_SLUG=dev

# URL pública de la driver PWA. Los invite/recovery links de choferes apuntan aquí.
# Prod: https://driver.verdfrut.com
DRIVER_APP_URL=http://localhost:3001
