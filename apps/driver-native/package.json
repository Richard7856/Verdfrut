{
  "name": "@tripdrive/driver-native",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "build:android": "npx -y eas-cli build --profile development --platform android",
    "build:preview": "npx -y eas-cli build --profile preview --platform android",
    "build:production": "npx -y eas-cli build --profile production --platform android",
    "submit:android": "npx -y eas-cli submit --platform android",
    "eas:login": "npx -y eas-cli login",
    "eas:init": "npx -y eas-cli init",
    "type-check": "tsc --noEmit",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@babel/runtime": "^7.25.0",
    "@expo/config-plugins": "~10.1.2",
    "@expo/metro-runtime": "~5.0.5",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/netinfo": "11.4.1",
    "@supabase/supabase-js": "^2.45.0",
    "@tripdrive/types": "workspace:*",
    "expo": "~53.0.0",
    "expo-asset": "~11.1.7",
    "expo-constants": "~17.1.8",
    "expo-device": "~7.1.4",
    "expo-file-system": "~18.1.11",
    "expo-font": "~13.3.2",
    "expo-image-manipulator": "~13.1.7",
    "expo-image-picker": "~16.1.4",
    "expo-keep-awake": "~14.1.4",
    "expo-linking": "~7.1.7",
    "expo-location": "~18.1.6",
    "expo-modules-autolinking": "2.1.15",
    "expo-modules-core": "2.5.0",
    "expo-notifications": "~0.31.5",
    "expo-router": "~5.1.11",
    "expo-splash-screen": "~0.30.0",
    "expo-sqlite": "~15.2.14",
    "expo-status-bar": "~2.2.3",
    "expo-system-ui": "~5.0.11",
    "expo-task-manager": "~13.1.6",
    "expo-updates": "~0.28.18",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~3.17.5",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-url-polyfill": "^2.0.0"
