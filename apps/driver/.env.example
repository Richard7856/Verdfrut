# Driver app — PWA para chofer y supervisor de zona.
# Copiar a .env.local y rellenar.

# Mismo Supabase del tenant que platform.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Push notifications. Las VAPID keys son las MISMAS en platform y driver
# (el chofer se suscribe desde la driver app y el platform envía desde el server).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@verdfrut.com

# Mapas. Token público (pk.*) para JS, token de Directions (sk.*) sólo server-side.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxx
MAPBOX_DIRECTIONS_TOKEN=sk.xxx

# IA para extracción de tickets (mismo key que platform).
ANTHROPIC_API_KEY=sk-ant-xxx

# App
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_TENANT_SLUG=dev
