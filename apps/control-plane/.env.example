# =============================================================================
# Control Plane VerdFrut — plantilla de variables de entorno
# =============================================================================
# Copia este archivo a .env.local y rellena los valores.
# .env.local NO se commitea (está en .gitignore).

# Auth
CP_SHARED_PASSWORD=                # Mínimo 8 chars. Para prod, 16+.
CP_COOKIE_SECRET=                  # openssl rand -hex 32

# Supabase (mismo proyecto que el tenant primario — ADR-030 Escenario 2)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Etiqueta de entorno mostrada en sidebar
NEXT_PUBLIC_ENV_LABEL=DEV
