auto-install-peers=true
strict-peer-dependencies=false

# node-linker=hoisted: usa node_modules tradicional flat (sin symlinks de
# pnpm isolated). Razón: Metro bundler + pnpm isolated NO se llevan bien;
# falla resolviendo peer deps transitivas (invariant, expo-modules-core,
# @babel/runtime, etc.). hoisted crea un node_modules estilo npm/yarn donde
# todas las deps se elevan al árbol, garantizando resolución correcta.
# Trade-off: usa más espacio en disco, pero el repo entero (web + native)
# instala sin problemas y los builds son deterministicos.
node-linker=hoisted
shamefully-hoist=true
