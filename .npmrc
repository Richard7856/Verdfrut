auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false
node-linker=isolated

# Public hoist patterns: elevan paquetes del ecosistema Expo/RN al root
# node_modules para que Metro bundler los resuelva sin que cada app las
# declare como deps directas. No afecta a Next.js apps (cada una sigue
# teniendo `next` en su propio node_modules — Vercel build feliz).
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=@babel/runtime
public-hoist-pattern[]=metro*
public-hoist-pattern[]=@react-navigation/*
public-hoist-pattern[]=invariant
public-hoist-pattern[]=fbjs
public-hoist-pattern[]=hermes-*
