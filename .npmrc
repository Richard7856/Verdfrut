auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false
node-linker=isolated

# Public hoist patterns para Expo monorepo (apps/driver-native).
# pnpm con node-linker=isolated NO eleva peers anidados al root node_modules,
# y Metro bundler los busca via tree-traversal. Estos patterns elevan
# paquetes del ecosistema Expo + RN + Babel runtime al root para que Metro
# los resuelva sin agregar cada uno explícitamente como dep directa.
# No afecta apps web (Next.js usa webpack/turbopack que NO necesitan estos).
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=@babel/runtime
public-hoist-pattern[]=metro*
public-hoist-pattern[]=@react-navigation/*
